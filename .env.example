# Backend API URL (defaults to production if not set)
EXPO_PUBLIC_API_BASE_URL=https://emsconnect.online/api

# Agora Voice Call App ID (optional - falls back to hardcoded production ID)
# Get your app ID from: https://console.agora.io/
# Only needed if you want to use a different Agora project in development
# EXPO_PUBLIC_AGORA_APP_ID=your_agora_app_id_here

# OpenRouteService - SYNCED WITH BACKEND
# Get your free API key from: https://openrouteservice.org/dev/#/signup
# ⚠️ IMPORTANT: Use the SAME key as your Laravel backend
EXPO_PUBLIC_ORS_API_KEY=YOUR_ORS_API_KEY_HERE
EXPO_PUBLIC_ORS_BASE_URL=https://api.openrouteservice.org/v2
